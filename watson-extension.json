{
  "openapi": "3.0.0",
  "info": {
    "title": "ReUse Watson Actions API",
    "version": "1.1.0",
    "description": "API para o IBM Watson Assistant executar acoes de itens no ReUse."
  },
  "servers": [
    {
      "url": "https://reuse-web.vercel.app",
      "description": "Producao"
    }
  ],
  "paths": {
    "/api/watson/execute": {
      "post": {
        "summary": "Executa uma acao do assistente",
        "operationId": "executeWatsonAction",
        "security": [
          { "ApiKeyAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": ["PAUSE_ALL", "ACTIVATE_ALL", "LIST_MY_ITEMS"],
                    "description": "Acao que o Watson deve executar"
                  },
                  "userEmail": {
                    "type": "string",
                    "format": "email",
                    "description": "Email do usuario dono dos itens"
                  },
                  "apiKey": {
                    "type": "string",
                    "description": "Opcional (fallback): chave secreta definida em WATSON_API_KEY."
                  }
                },
                "required": ["action", "userEmail"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Acao executada",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "action": { "type": "string" },
                    "userEmail": { "type": "string" },
                    "count": { "type": "integer" },
                    "message": { "type": "string" },
                    "itemsText": { "type": "string" },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "string" },
                          "title": { "type": "string" },
                          "status": { "type": "string" },
                          "category": { "type": "string", "nullable": true },
                          "condition": { "type": "string", "nullable": true },
                          "city": { "type": "string", "nullable": true },
                          "state": { "type": "string", "nullable": true },
                          "updatedAt": { "type": "string", "format": "date-time" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Erro de validacao"
          },
          "401": {
            "description": "Api key invalida"
          },
          "404": {
            "description": "Usuario nao encontrado"
          },
          "500": {
            "description": "Erro interno"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  }
}
